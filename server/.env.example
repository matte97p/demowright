# demowright render service — environment variables.
#
# Copy to .env for LOCAL runs only (`.env` is gitignored / dockerignored).
# In production set these via `gcloud run deploy --set-env-vars` (or, for
# hardening, Secret Manager + --set-secrets). NEVER commit real keys.

# --- Required: service gate ---
# Bearer token required on POST /render. The server REFUSES TO START if unset.
# Generate a strong one: openssl rand -hex 32
SERVICE_API_KEY=

# --- Required: Cloudflare R2 (S3-compatible) ---
# Use a token scoped to ONE bucket with Object Read & Write — not account-wide
# creds, not the global Cloudflare API key.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=demowright-renders
# Public base for returned links (the bucket's r2.dev public URL or a custom
# domain). This is NOT the S3 endpoint (…r2.cloudflarestorage.com is not public).
R2_PUBLIC_BASE_URL=

# --- Optional: server-default voice keys ---
# Fallback used when a request omits voiceKeys. Per-request voiceKeys win.
# OPENAI_API_KEY=
# ELEVENLABS_API_KEY=

# --- Optional: tuning ---
# Extra env names a request may set via voiceKeys (comma-separated). The two
# built-ins below are always allowed; list only ADDITIONS here.
# ALLOWED_KEY_ENVS=OPENAI_API_KEY,ELEVENLABS_API_KEY
# Max request body in bytes (rejected pre-parse with 413). Default 2000000.
# MAX_BODY_BYTES=2000000
# Render wall-clock cap in ms (keep under Cloud Run's 3600s). Default 3000000.
# RENDER_TIMEOUT_MS=3000000

# PORT is injected by Cloud Run; do not set it in production. Local default 8080.
# PORT=8080
